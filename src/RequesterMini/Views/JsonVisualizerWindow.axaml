<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:RequesterMini.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:JsonVisualizerWindowViewModel"
             x:Class="RequesterMini.Views.JsonVisualizerWindow">

    <Design.DataContext>
        <vm:JsonVisualizerWindowViewModel/>
    </Design.DataContext>

    <ScrollViewer Background="#1E1E1E">
        <SelectableTextBlock x:Name="JsonTextBlock"
                             FontFamily="Consolas, monospace"
                             FontSize="13"
                             Foreground="#D4D4D4"
                             Margin="12"
                             TextWrapping="Wrap" />
    </ScrollViewer>
</UserControl>